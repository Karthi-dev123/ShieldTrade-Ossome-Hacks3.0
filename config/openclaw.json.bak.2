{
  "$schema": "https://openclaw.ai/schemas/config/2026.3.json",
  "gateway": {
    "mode": "local"
  },
  "plugins": {
    "allow": ["groq", "armoriq", "@openclaw/armoriq", "armorclaw"],
    "entries": {
      "groq": {
        "enabled": true
      },
      "armoriq": {
        "enabled": true
      }
    }
  },
  "skills": {
    "load": {
      "extraDirs": ["../skills"]
    }
  }
}
