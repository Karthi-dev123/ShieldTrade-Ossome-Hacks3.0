{
  "$schema": "https://openclaw.ai/schemas/config/2026.3.json",
  "name": "shieldtrade",
  "version": "0.1.0",

  "llm": {
    "provider": "groq",
    "model": "llama3-70b-8192",
    "apiKey": "${GROQ_API_KEY}",
    "temperature": 0.1,
    "maxTokens": 4096
  },

  "plugins": {
    "allow": ["groq", "armorclaw"],
    "entries": {
      "groq": { "enabled": true },
      "armorclaw": {
        "enabled": true,
        "apiKey": "${ARMORIQ_API_KEY}",
        "enforcement": "fail-closed",
        "policyFile": "./shieldtrade-policies.yaml"
      }
    }
  },

  "agents": {
    "analyst": {
      "description": "Market data analyst. Fetches quotes, runs technical analysis, writes recommendations.",
      "allowedTools": ["fetch_market_data", "analyze_ticker", "write_report"],
      "writeAccess": ["output/reports", "output/thoughts/analyst.jsonl"],
      "readAccess": ["data/market", "data/earnings"]
    },
    "risk_manager": {
      "description": "Policy enforcer. Validates analyst recommendations against risk thresholds, issues delegation tokens.",
      "allowedTools": ["evaluate_risk", "check_policy", "issue_delegation"],
      "writeAccess": ["output/risk-decisions", "output/thoughts/risk-manager.jsonl"],
      "readAccess": ["output/reports", "output/thoughts/analyst.jsonl"]
    },
    "trader": {
      "description": "Execution agent. Places paper trades within delegation bounds via Alpaca API.",
      "allowedTools": ["place_order", "check_position", "log_trade"],
      "writeAccess": ["output/trade-logs", "output/thoughts/trader.jsonl"],
      "readAccess": ["output/risk-decisions"]
    }
  },

  "tools": {
    "registrationMode": "explicit",
    "globalDenied": ["shell", "exec", "web_fetch"]
  }
}
