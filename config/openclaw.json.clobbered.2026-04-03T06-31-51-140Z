{
  "$schema": "https://openclaw.ai/schemas/config/2026.3.json",
  "gateway": {
    "mode": "local"
  },
  "plugins": {
    "allow": ["groq", "armoriq", "@openclaw/armoriq", "armorclaw"],
    "entries": {
      "groq": {
        "enabled": true
      },
      "armoriq": {
        "enabled": true
      },
      "armorclaw": {
        "enabled": true
      }
    }
  },
  "skills": {
    "load": {
      "extraDirs": ["../skills"]
    }
  },
  "agents": {
    "defaults": {
      "model": "groq:llama3-70b-8192"
    }
  }
}
