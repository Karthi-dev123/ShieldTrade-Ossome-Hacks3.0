{
  "$schema": "https://openclaw.ai/schemas/config/2026.3.json",
  "agents": {
    "defaults": {
      "model": "google/gemini-3-flash-preview"
    }
  },
  "models": {
    "providers": {
      "google": {
        "baseUrl": "http://localhost:4000/v1",
        "apiKey": "proxy-managed",
        "models": [
          {
            "id": "gemini-3-flash-preview",
            "name": "Gemini 3 Flash",
            "api": "openai-completions",
            "contextWindow": 1000000
          }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "d17d4ab08c80922f2bff84cedcad95e54b75e7c2d16ebb01"
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "../skills"
      ]
    }
  },
  "plugins": {
    "allow": [
      "google",
      "armoriq"
    ],
    "entries": {
      "google": {
        "enabled": true
      },
      "armoriq": {
        "enabled": true
      }
    }
  }
}
