{
  "$schema": "https://openclaw.ai/schemas/config/2026.3.json",
  "agents": {
    "defaults": {
      "model": "proxy/local-ollama"
    },
    "list": [
      {
        "id": "shieldtrade-analyst",
        "name": "ShieldTrade Analyst",
        "model": "proxy/local-ollama",
        "skills": ["shieldtrade-analyst"],
        "workspace": "."
      },
      {
        "id": "shieldtrade-risk-manager",
        "name": "ShieldTrade Risk Manager",
        "model": "proxy/local-ollama",
        "skills": ["shieldtrade-risk-manager"],
        "workspace": "."
      },
      {
        "id": "shieldtrade-trader",
        "name": "ShieldTrade Trader",
        "model": "proxy/local-ollama",
        "skills": ["shieldtrade-trader"],
        "workspace": "."
      }
    ]
  },
  "models": {
    "providers": {
      "proxy": {
        "baseUrl": "http://localhost:4000/v1",
        "apiKey": "proxy-managed",
        "api": "openai-completions",
        "models": [
          {
            "id": "local-ollama",
            "name": "Local Ollama (via ShieldTrade proxy)"
          }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "./skills"
      ]
    }
  },
  "plugins": {
    "allow": [
      "google",
      "armorclaw"
    ],
    "entries": {
      "google": {
        "enabled": true
      },
      "armorclaw": {
        "enabled": true,
        "config": {
          "enabled": true,
          "apiKey": "${ARMORIQ_API_KEY}",
          "userId": "shieldtrade-user",
          "agentId": "shieldtrade-pipeline",
          "contextId": "shieldtrade",
          "validitySeconds": 300,
          "policy": {
            "allow": ["bash", "read", "write", "web_fetch"],
            "deny": []
          },
          "cryptoPolicyEnabled": false
        }
      }
    }
  }
}
