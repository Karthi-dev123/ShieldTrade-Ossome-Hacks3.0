{
  "$schema": "https://openclaw.ai/schemas/config/2026.3.json",
  "models": {
    "providers": {
      "groq": {
        "baseUrl": "https://api.groq.com/openai/v1",
        "models": ["llama3-8b-8192", "llama3-70b-8192"],
        "apiKey": "${GROQ_API_KEY}"
      }
    }
  },
  "plugins": {
    "allow": ["groq", "armoriq"],
    "entries": {
      "groq": {
        "enabled": true
      },
      "armoriq": {
        "enabled": true
      }
    }
  },
  "skills": {
    "load": {
      "extraDirs": ["../skills"]
    }
  }
}
