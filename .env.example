# Alpaca Paper Trading
ALPACA_API_KEY=your_paper_trading_key_here
ALPACA_SECRET_KEY=your_paper_trading_secret_here

# ArmorIQ / OpenClaw
ARMORIQ_API_KEY=ak_live_your_key_here

# Anthropic
ANTHROPIC_API_KEY=your_claude_api_key_here

# Local Ollama (primary model backend)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:30b-a3b
# Fast 8B model for the Streamlit UI demo (set UI_LLM_MODEL to override)
UI_LLM_MODEL=qwen3:8b
OLLAMA_API_KEY=

# OpenClaw Gateway
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# Supabase (audit logging — optional, logging is skipped if unset)
SUPABASE_URL=https://your-project-ref.supabase.co
# Prefer service_role key for inserts; anon key only if RLS allows policy_checks / trade_events
SUPABASE_SERVICE_KEY=your_service_role_key_here
# SUPABASE_ANON_KEY=your_anon_key_here
